# Copy to .env.local and fill in.
#
# Anthropic API key — used by the Python function to authenticate
# ClaudeSDKClient. In production, set via `vercel env add ANTHROPIC_API_KEY`.
ANTHROPIC_API_KEY=sk-ant-...

# Local dev only: permit the Python "sandbox" to run as a subprocess on your
# laptop instead of a Firecracker microVM. Set to 1 when iterating without
# `vercel dev` or an OIDC token. NEVER set this in production.
ALLOW_INPROCESS_SANDBOX=1

# Optional: override the Python function URL that the Next.js dev proxy hits.
# Default is http://localhost:3000/api/agent (the path that `vercel dev`
# mounts). Only set this if you run the Python function on a different port.
# PY_AGENT_URL=http://localhost:3000/api/agent
