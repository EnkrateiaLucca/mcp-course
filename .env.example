# ------------------------------------------------------------------
# Environment template for "Building AI Agents with MCP"
#
# Copy this file to `.env` at the REPO ROOT and fill in your real values:
#     cp .env.example .env
#
# `.env` is gitignored — your real keys stay local and are never committed.
# The notebooks/scripts load it via `load_dotenv()`, which searches upward
# from each demo folder, so the file must live at the repo root to be found.
# ------------------------------------------------------------------

# Required for all Claude agent demos (00, 01, 02, 03, 04, 05, ...)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required only for the OpenAI Agents SDK demo (assets-resources/openai_mcp_csv_demo)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional — demo 04 bearer auth on the HTTP transport
MCP_AUTH_TOKEN=demo-secret

# Optional — only for demo 04's image-generation extra
REPLICATE_API_TOKEN=your-replicate-token-here
